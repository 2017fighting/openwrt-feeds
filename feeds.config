{
  "_comment": "Source of truth for the build matrix (.github/workflows/build.yml reads this with jq). Each object = one SDK + one build job. Add a version/arch by appending an object. Fields: openwrt_version (tagged release), arch (apk package architecture), target/subtarget (SDK tarball segments), goarch (Go GOARCH), gcc_ver (SDK tarball segment).",
  "feeds": [
    { "openwrt_version": "25.12.4", "arch": "x86_64",          "target": "x86",   "subtarget": "64",    "goarch": "amd64", "gcc_ver": "14.3.0" },
    { "openwrt_version": "25.12.4", "arch": "aarch64_generic", "target": "armsr", "subtarget": "armv8", "goarch": "arm64", "gcc_ver": "14.3.0" }
  ]
}
