# Supported OpenWrt feeds (version x arch) that this repo builds and publishes.
#
# Each entry maps an apk package architecture to the OpenWrt target/subtarget
# whose SDK we download, plus the GOARCH used to cross-compile Go packages.
#
# v1 builds the single entry below. The matrix in .github/workflows/build.yml
# is inlined from this for now; once a second entry is added, generate the
# workflow matrix from this file (jq/fromJson) instead of hard-coding it.
#
#   openwrt_version : tagged OpenWrt release (apk era: 24.10+/25.12+)
#   arch            : apk package architecture (== index.json "architecture")
#   target          : OpenWrt target  (SDK tarball name segment, e.g. x86)
#   subtarget       : OpenWrt subtarget (e.g. 64)
#   goarch          : GOARCH for Go cross-compile (e.g. amd64)
feeds:
  - openwrt_version: "25.12.4"
    arch: "x86_64"
    target: "x86"
    subtarget: "64"
    goarch: "amd64"
