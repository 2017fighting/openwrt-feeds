msgid "MosDNS"
msgstr "MosDNS"

msgid "RUNNING"
msgstr "运行中"

msgid "NOT RUNNING"
msgstr "未运行"

msgid "Collecting data..."
msgstr "获取数据中..."

msgid "Enabled"
msgstr "启用"

msgid "Config File"
msgstr "配置文件"

msgid "DNS Forward"
msgstr "DNS 转发"

msgid "Forward Dnsmasq DNS requests to MosDNS (parses the listen port from the YAML)."
msgstr "将 Dnsmasq 域名解析请求转发到 MosDNS（监听端口从 YAML 中解析）。"

msgid "Configuration Editor"
msgstr "配置编辑器"

msgid "Direct edit of the mosdns pipeline. Save writes the file and restarts mosdns."
msgstr "直接编辑 mosdns 配置流水线。保存会写入文件并重启 mosdns。"

msgid "Unable to save contents: %s"
msgstr "无法保存内容：%s"

msgid "Unable to apply: %s"
msgstr "无法应用：%s"

msgid "Log Data"
msgstr "日志数据"

msgid "No log data."
msgstr "无日志数据。"

msgid "Failed to clean logs."
msgstr "清理日志失败：%s"

msgid "Clear logs"
msgstr "清空日志"

msgid "Refresh every %s seconds."
msgstr "每 %s 秒刷新。"

msgid "Cloudflare Speedtest"
msgstr "Cloudflare 优选"

msgid "Re-probe now"
msgstr "立即重新测速"

msgid "Probing..."
msgstr "测速中..."

msgid "Re-probe triggered. The cache refreshes when the scan completes."
msgstr "已触发重新测速。扫描完成后缓存将刷新。"

msgid "Re-probe failed: %s"
msgstr "重新测速失败：%s"

msgid "Status refreshes automatically. Re-probe sends SIGUSR1 to mosdns."
msgstr "状态自动刷新。重新测速会向 mosdns 发送 SIGUSR1 信号。"

msgid "Cache file"
msgstr "缓存文件"

msgid "Last refresh"
msgstr "上次刷新"

msgid "Download URL"
msgstr "测速 URL"

msgid "Probe port"
msgstr "测速端口"

msgid "Top-N retained"
msgstr "保留最优 IP 数"

msgid "Refresh interval"
msgstr "刷新间隔"

msgid "Sample mode"
msgstr "采样模式"

msgid "default (21600 s)"
msgstr "默认（21600 秒）"

msgid "no cache yet — run a probe"
msgstr "暂无缓存 — 请执行一次测速"

msgid "Optimized IPs"
msgstr "优选 IP"

msgid "never"
msgstr "从未"

msgid "just now"
msgstr "刚刚"

msgid "%d s ago"
msgstr "%d 秒前"

msgid "%d m ago"
msgstr "%d 分钟前"

msgid "%d h ago"
msgstr "%d 小时前"

msgid "%d d ago"
msgstr "%d 天前"

msgid "Error: %s"
msgstr "错误：%s"

msgid "Rule Settings"
msgstr "规则列表"

msgid "List files referenced by /etc/mosdns/config_custom.yaml. Save & Apply writes the files and restarts mosdns."
msgstr "被 /etc/mosdns/config_custom.yaml 引用的列表文件。保存并应用会写入文件并重启 mosdns。"

msgid "White Lists"
msgstr "白名单"

msgid "Domains here are always forwarded to upstream with the highest priority (one domain per line)."
msgstr "此处的域名始终以最高优先级转发到上游（每行一个域名）。"

msgid "Hosts"
msgstr "Hosts"

msgid "Custom hosts rewrite, e.g. example.com 10.0.0.1 (one rule per line)."
msgstr "自定义 hosts 重写，例如 example.com 10.0.0.1（每行一条）。"

msgid "Cloudflare CIDR"
msgstr "Cloudflare CIDR"

msgid "Cloudflare CIDR ranges whose response IPs trigger cfst_pool/lpush (one CIDR per line)."
msgstr "响应 IP 命中后将触发 cfst_pool/lpush 的 Cloudflare CIDR 范围（每行一条）。"

msgid "Basic Setting"
msgstr "基本设置"

msgid "Rules"
msgstr "规则列表"

msgid "Logs"
msgstr "日志"
